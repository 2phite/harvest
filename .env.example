# bili-tool configuration — copy to `.env` and fill in. NEVER commit the real `.env`.

# --- Vision: LM Studio (OpenAI-compatible endpoint) ---
# LM Studio may require a Bearer API token (Settings > Developer > "Require API key").
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_API_KEY=
# Exact Qwen3-VL model id (must be loaded in LM Studio WITH its mmproj projector).
LMSTUDIO_VISION_MODEL=

# --- Auth (D9) ---
# Default: yt-dlp reads cookies live from your logged-in browser (BILI_COOKIES_* below).
# Fallback (headless / no browser): paste a SESSDATA cookie value here.
# SESSDATA=

# --- Cookies-from-browser (D9 default) ---
# On Windows, Firefox is the reliable choice (Chromium browsers DPAPI-encrypt the cookie DB).
BILI_COOKIES_BROWSER=firefox
BILI_COOKIES_PROFILE=

# --- Optional overrides (otherwise sensible defaults in config.py) ---
# BILI_CACHE_DIR=cache
# BILI_OUT_DIR=out
# FFMPEG_PATH=
